  </requires>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.1.2" date="2026-03-25">
      <description>
        <p>New features and improvements:</p>
        <ul>
          <li>Custom color theme: choose your own accent, background, and text/icon colors</li>
          <li>Color pickers with per-color reset button to restore system defaults</li>
        </ul>
      </description>
    </release>
    <release version="0.1.1" date="2025-03-25">
      <description>
        <p>Improvements and bug fixes:</p>
        <ul>
          <li>MPRIS album art and artist now work for YouTube streams</li>
          <li>App icon now displays correctly in system media controls</li>
          <li>Recent files list now tracks all played items including auto-advanced tracks</li>
          <li>Opening a recent file moves it to the top of the list</li>
          <li>M3U playlists are no longer added to recent files</li>
          <li>Spanish translation improvements</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2025-01-01">
      <description>
        <p>Initial release of Aurora Media Player.</p>
      </description>
    </release>
  </releases>
</component>
