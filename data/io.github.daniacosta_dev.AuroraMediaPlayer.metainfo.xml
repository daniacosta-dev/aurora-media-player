<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.daniacosta_dev.AuroraMediaPlayer</id>

  <name>Aurora Media Player</name>
  <summary>Modern and customizable media player</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      Aurora Media Player is a modern, clean media player built with GTK4 and
      libadwaita. Powered by mpv, it supports virtually all video and audio
      formats with high-quality hardware-accelerated playback.
    </p>
    <p>Features:</p>
    <ul>
      <li>Plays all common video formats: MP4, MKV, AVI, MOV, WebM and more</li>
      <li>Plays all common audio formats: MP3, FLAC, OGG, Opus, AAC and more</li>
      <li>Stream YouTube and other sites via yt-dlp integration</li>
      <li>Playlist management with shuffle and repeat modes</li>
      <li>Session restore — resumes playback where you left off</li>
      <li>Recent files list for quick access</li>
      <li>Audio metadata display with album art</li>
      <li>Multi-track audio and subtitle selection</li>
      <li>Hardware-accelerated decoding via VA-API</li>
      <li>MPRIS support for system media controls</li>
      <li>Custom color theme — pick your own accent, background, and text colors</li>
    </ul>
  </description>

  <developer id="io.github.daniacosta_dev">
    <name>Daniel Acosta</name>
  </developer>

  <url type="homepage">https://github.com/daniacosta-dev/aurora-media-player</url>
  <url type="bugtracker">https://github.com/daniacosta-dev/aurora-media-player/issues</url>

  <launchable type="desktop-id">io.github.daniacosta_dev.AuroraMediaPlayer.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <caption>Video playback with controls</caption>
      <image>https://raw.githubusercontent.com/daniacosta-dev/aurora-media-player/main/data/screenshots/videoplayer1.png</image>
    </screenshot>
    <screenshot>
      <caption>Audio playback with album art</caption>
      <image>https://raw.githubusercontent.com/daniacosta-dev/aurora-media-player/main/data/screenshots/videoplayer2.png</image>
    </screenshot>
    <screenshot>
      <caption>Playlist management</caption>
      <image>https://raw.githubusercontent.com/daniacosta-dev/aurora-media-player/main/data/screenshots/videoplayer3.png</image>
    </screenshot>
  </screenshots>

  <provides>
    <binary>aurora-media</binary>
  </provides>

  <categories>
    <category>AudioVideo</category>
    <category>Video</category>
    <category>Audio</category>
    <category>Player</category>
    <category>GTK</category>
  </categories>

  <keywords>
    <keyword>media</keyword>
    <keyword>player</keyword>
    <keyword>video</keyword>
    <keyword>audio</keyword>
    <keyword>mpv</keyword>
    <keyword>music</keyword>
    <keyword>youtube</keyword>
  </keywords>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>

  <requires>
